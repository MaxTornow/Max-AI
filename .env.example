VITE_TIKTOK_API_TOKEN=your_tiktok_api_token_here
VITE_ASSEMBLY_AI_API_KEY=your_assembly_ai_api_key_here
# Claude API key (server-side only — must also be set in Netlify env vars)
CLAUDE_API_KEY=your_claude_api_key_here

# AVA Webhook URLs
